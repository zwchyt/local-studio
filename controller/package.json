{
  "name": "local-studio-controller",
  "version": "0.3.2",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test:integration": "bun test ../tests/controller/integration",
    "typecheck": "tsc --noEmit",
    "standards": "bun scripts/controller-standards-audit.ts",
    "check": "knip && jscpd src && depcheck --skip-missing",
    "check:fix": "knip --fix"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.78.1",
    "@hono/swagger-ui": "0.5.3",
    "dotenv": "16.6.1",
    "hono": "4.6.12",
    "prom-client": "15.1.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.6.0",
    "@typescript-eslint/eslint-plugin": "8.43.0",
    "@typescript-eslint/parser": "8.43.0",
    "bun-types": "1.3.6",
    "depcheck": "1.4.7",
    "eslint": "9.35.0",
    "eslint-plugin-unicorn": "60.0.0",
    "jscpd": "4.0.5",
    "knip": "5.44.2",
    "prettier": "3.4.2",
    "typescript": "5.9.2"
  }
}
